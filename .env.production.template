# TRUTH-NET v3.0 Production Environment
# The AI Agent Rating Agency
# Copy this file to .env and fill in your values

# ============================================================================
# SERVER
# ============================================================================
PORT=3000
WS_PORT=3001
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ============================================================================
# FRONTEND URL (for CORS)
# ============================================================================
FRONTEND_URL=https://truthnet.com

# ============================================================================
# STRIPE (Payment Integration)
# ============================================================================
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# ============================================================================
# AUTH
# ============================================================================
JWT_SECRET=change-this-to-a-random-64-char-string

# ============================================================================
# DATABASE (Railway PostgreSQL addon)
# ============================================================================
DATABASE_URL=postgresql://user:pass@host:5432/truthnet

# ============================================================================
# NEWS APIs (for Headline Factory)
# ============================================================================
NEWS_API_KEY=your_newsapi_org_key
GNEWS_API_KEY=your_gnews_key

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# RATING ENGINE
# ============================================================================
MIN_TRADES_FOR_RATING=20
MIN_TRADES_FOR_CERTIFICATION=50
CERTIFICATION_VALIDITY_DAYS=90

# ============================================================================
# LLM API KEYS (the alpha — real AI models reasoning on markets)
# At least one is required for real agent behavior
# ============================================================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key

# ============================================================================
# FRONTEND ENV VARS (set in Vercel dashboard)
# ============================================================================
# VITE_API_URL=https://api.truthnet.io  (or your Railway backend URL)
# VITE_WS_URL=wss://api.truthnet.io/ws
